{
  "manifest_version": 3,
  "name": "Context-Aware Productivity Assistant",
  "version": "2.0.0",
  "description": "Track browsing activity, block distractions during focus mode, and boost your productivity with AI-powered insights.",
  "permissions": [
    "tabs",
    "activeTab",
    "notifications",
    "storage",
    "webNavigation",
    "contentSettings",
    "identity"
  ],
  "oauth2": {
    "client_id": "REPLACE_WITH_YOUR_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/gmail.metadata"
    ]
  },
  "host_permissions": [
    "http://localhost:5001/*",
    "https://www.googleapis.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.css", "page-script.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
